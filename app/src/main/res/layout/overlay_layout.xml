<?xml version="1.0" encoding="utf-8"?>
<!-- Root is LinearLayout (NOT FrameLayout) — bg applied in code via setBackground().
     Drawable alpha only affects the drawable, not child views, so text stays 100% opaque. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlayRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingLeft="12dp"
    android:paddingRight="12dp"
    android:paddingTop="6dp"
    android:paddingBottom="2dp">

    <!-- Single row: activity text left, time right, reset + close -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Activity name (tap to edit) -->
        <EditText
            android:id="@+id/activityInput"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:hint="tap to start"
            android:singleLine="true"
            android:imeOptions="actionDone"
            android:inputType="text"
            android:background="@android:color/transparent"
            android:textSize="14sp"
            android:minWidth="60dp"
            android:maxWidth="180dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:paddingLeft="0dp"
            android:paddingRight="0dp"
            android:fontFamily="sans-serif" />

        <!-- Separator (shown when timer is visible) -->
        <TextView
            android:id="@+id/separator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" · "
            android:textSize="14sp"
            android:visibility="gone" />

        <!-- Timer (tap to pause/resume) -->
        <TextView
            android:id="@+id/timerText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:paddingLeft="0dp"
            android:paddingRight="0dp"
            android:visibility="gone" />

        <!-- Reset (save + restart same activity) -->
        <TextView
            android:id="@+id/resetBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" ↺"
            android:textSize="13sp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:paddingLeft="6dp"
            android:paddingRight="0dp"
            android:visibility="gone" />

        <!-- Close overlay (shown only in edit mode) -->
        <TextView
            android:id="@+id/closeBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" ×"
            android:textSize="13sp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:paddingLeft="6dp"
            android:paddingRight="0dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Thin accent line at bottom (hidden until timer starts) -->
    <FrameLayout
        android:id="@+id/progressContainer"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_marginTop="2dp"
        android:visibility="gone">

        <View
            android:id="@+id/progressTrack"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <View
            android:id="@+id/progressBar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0" />
    </FrameLayout>

</LinearLayout>
