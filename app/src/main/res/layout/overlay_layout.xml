<?xml version="1.0" encoding="utf-8"?>
<!-- Root is LinearLayout — bg + border applied in code via setBackground().
     Drawable alpha only affects the drawable, not child views, so text stays 100% opaque. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlayRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="5dp">

    <!-- Single row: activity text left, time right, reset + close -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Activity name (tap to edit) -->
        <EditText
            android:id="@+id/activityInput"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:hint="tap to start"
            android:singleLine="true"
            android:imeOptions="actionDone"
            android:inputType="text"
            android:background="@android:color/transparent"
            android:textSize="14sp"
            android:minWidth="60dp"
            android:maxWidth="180dp"
            android:padding="0dp"
            android:fontFamily="sans-serif" />

        <!-- Separator (shown when timer is visible) -->
        <TextView
            android:id="@+id/separator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" - "
            android:textSize="14sp"
            android:visibility="gone" />

        <!-- Timer (tap to pause/resume) -->
        <TextView
            android:id="@+id/timerText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:padding="0dp"
            android:visibility="gone" />

        <!-- Reset (save + pause timer) -->
        <TextView
            android:id="@+id/resetBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" ↺"
            android:textSize="14sp"
            android:paddingLeft="8dp"
            android:paddingRight="2dp"
            android:visibility="gone" />

        <!-- Close overlay (shown only in edit mode) -->
        <TextView
            android:id="@+id/closeBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" ×"
            android:textSize="14sp"
            android:paddingLeft="6dp"
            android:paddingRight="0dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Day timeline bar: colored segments proportional to each activity's duration -->
    <com.timetracker.overlay.TimelineBarView
        android:id="@+id/timelineBar"
        android:layout_width="match_parent"
        android:layout_height="5dp"
        android:layout_marginTop="3dp"
        android:visibility="gone" />

</LinearLayout>
